    },
    {
      "type": "text",
      "version": 1,
      "versionNonce": 1,
      "isDeleted": false,
      "id": "redundancy-details",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "angle": 0,
      "x": 570,
      "y": 880,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "width": 430,
      "height": 200,
      "seed": 1,
      "groupIds": [],
      "frameId": null,
      "roundness": null,
      "boundElements": [],
      "updated": 1,
      "link": null,
      "locked": false,
      "fontSize": 13,
      "fontFamily": 3,
      "text": "Thread (0,0) and Thread (1,0) BOTH read:\nRow 0 of A: [a00,a01,a02,a03]\n\nBut they read it INDEPENDENTLY from global memory!\n\nFor 4×4:\n• Each thread reads 8 elements (4A + 4B)\n• 16 threads × 8 = 128 total reads\n• But A and B only have 16 unique elements each\n• 128 reads vs 32 unique elements = 4× redundancy!\n\nFor 1024×1024:\n• 1,048,576 threads × 2,048 reads = 2.1B reads\n• But only 2M unique elements total\n• ~1000× redundancy!",
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Thread (0,0) and Thread (1,0) BOTH read:\nRow 0 of A: [a00,a01,a02,a03]\n\nBut they read it INDEPENDENTLY from global memory!\n\nFor 4×4:\n• Each thread reads 8 elements (4A + 4B)\n• 16 threads × 8 = 128 total reads\n• But A and B only have 16 unique elements each\n• 128 reads vs 32 unique elements = 4× redundancy!\n\nFor 1024×1024:\n• 1,048,576 threads × 2,048 reads = 2.1B reads\n• But only 2M unique elements total\n• ~1000× redundancy!",
      "lineHeight": 1.25
    },
