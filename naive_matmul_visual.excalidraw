      "fontSize": 20,
      "fontFamily": 1,
      "text": "TRACE: Thread Computing C[0,0]",
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": null,
      "originalText": "TRACE: Thread Computing C[0,0]",
      "lineHeight": 1.25
    },
    {
      "type": "text",
      "version": 1,
      "versionNonce": 1,
      "isDeleted": false,
      "id": "trace-details",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "angle": 0,
      "x": 50,
      "y": 880,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "width": 500,
      "height": 200,
      "seed": 1,
      "groupIds": [],
      "frameId": null,
      "roundness": null,
      "boundElements": [],
      "updated": 1,
      "link": null,
      "locked": false,
      "fontSize": 13,
      "fontFamily": 3,
      "text": "Position: blockIdx=(0,0), threadIdx=(0,0)\nrow=0, col=0\n\nStep 1: row, col = cuda.grid(2)  → row=0, col=0\nStep 2: if 0<4 and 0<4 → TRUE (does work)\nStep 3: acc = 0.0\n\nStep 4: Loop k=0..3\n  k=0: acc += A[0,0] * B[0,0]  → acc = a00*b00\n  k=1: acc += A[0,1] * B[1,0]  → acc = a00*b00 + a01*b10\n  k=2: acc += A[0,2] * B[2,0]  → acc += a02*b20\n  k=3: acc += A[0,3] * B[3,0]  → acc += a03*b30\n\nStep 5: C[0,0] = acc\nResult: C[0,0] = a00*b00 + a01*b10 + a02*b20 + a03*b30",
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Position: blockIdx=(0,0), threadIdx=(0,0)\nrow=0, col=0\n\nStep 1: row, col = cuda.grid(2)  → row=0, col=0\nStep 2: if 0<4 and 0<4 → TRUE (does work)\nStep 3: acc = 0.0\n\nStep 4: Loop k=0..3\n  k=0: acc += A[0,0] * B[0,0]  → acc = a00*b00\n  k=1: acc += A[0,1] * B[1,0]  → acc = a00*b00 + a01*b10\n  k=2: acc += A[0,2] * B[2,0]  → acc += a02*b20\n  k=3: acc += A[0,3] * B[3,0]  → acc += a03*b30\n\nStep 5: C[0,0] = acc\nResult: C[0,0] = a00*b00 + a01*b10 + a02*b20 + a03*b30",
      "lineHeight": 1.25
    },
