    {
      "type": "text",
      "version": 1,
      "versionNonce": 1,
      "isDeleted": false,
      "id": "sync-details",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "angle": 0,
      "x": 520,
      "y": 1070,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "width": 430,
      "height": 150,
      "seed": 1,
      "groupIds": [],
      "frameId": null,
      "roundness": null,
      "boundElements": [],
      "updated": 1,
      "link": null,
      "locked": false,
      "fontSize": 13,
      "fontFamily": 3,
      "text": "SYNC 1 (after load):\n• Prevents READ-AFTER-WRITE hazard\n• Ensures all threads loaded before anyone reads\n• Without it: thread reads garbage while another still loading\n\nSYNC 2 (after compute):\n• Prevents WRITE-AFTER-READ hazard\n• Ensures all threads finished before tile overwritten\n• Without it: fast thread overwrites while slow thread still reading\n\nBoth are MANDATORY — missing either causes race conditions!",
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "SYNC 1 (after load):\n• Prevents READ-AFTER-WRITE hazard\n• Ensures all threads loaded before anyone reads\n• Without it: thread reads garbage while another still loading\n\nSYNC 2 (after compute):\n• Prevents WRITE-AFTER-READ hazard\n• Ensures all threads finished before tile overwritten\n• Without it: fast thread overwrites while slow thread still reading\n\nBoth are MANDATORY — missing either causes race conditions!",
      "lineHeight": 1.25
    },
