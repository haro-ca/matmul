    },
    {
      "type": "text",
      "version": 1,
      "versionNonce": 1,
      "isDeleted": false,
      "id": "trace-details",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "angle": 0,
      "x": 50,
      "y": 740,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "width": 900,
      "height": 250,
      "seed": 1,
      "groupIds": [],
      "frameId": null,
      "roundness": null,
      "boundElements": [],
      "updated": 1,
      "link": null,
      "locked": false,
      "fontSize": 12,
      "fontFamily": 3,
      "text": "Thread: tx=0, ty=0, row=0, col=0, acc = 0.0\n\nITERATION t=0 (Load first tile):\n  Thread (0,0) loads: sA[0,0] = A[0,0] = a00\n  Thread (1,0) loads: sA[0,1] = A[0,1] = a01\n  Thread (0,1) loads: sA[1,0] = A[1,0] = a10\n  Thread (1,1) loads: sA[1,1] = A[1,1] = a11\n  All threads load their B elements into sB\n  SYNC 1: Wait for all loads\n\n  Each thread computes partial product from shared memory:\n  Thread (0,0): acc += sA[0,0]*sB[0,0] + sA[0,1]*sB[1,0] = a00*b00 + a01*b10\n  Thread (0,1): acc += sA[1,0]*sB[0,0] + sA[1,1]*sB[1,0] = a10*b00 + a11*b10\n  Thread (1,0): acc += sA[0,0]*sB[0,1] + sA[0,1]*sB[1,1] = a00*b01 + a01*b11\n  Thread (1,1): acc += sA[1,0]*sB[0,1] + sA[1,1]*sB[1,1] = a10*b01 + a11*b11\n  SYNC 2: Wait for all computes before overwriting\n\n  After t=0 (PARTIAL):\n  Thread (0,0): acc = a00*b00 + a01*b10\n  Thread (1,0): acc = a00*b01 + a01*b11\n  Thread (0,1): acc = a10*b00 + a11*b10\n  Thread (1,1): acc = a10*b01 + a11*b11\n\nITERATION t=1 (Load second tile):\n  Load A[:,2:4] into sA, B[2:4,:] into sB\n  SYNC 1\n  Compute: acc += sA[0,0]*sB[0,0] + sA[0,1]*sB[1,0] = a02*b20 + a03*b30\n  SYNC 2\n\n  After t=1 (COMPLETE):\n  Thread (0,0): acc = (a00*b00 + a01*b10) + (a02*b20 + a03*b30)\n  Thread (1,0): acc = (a00*b01 + a01*b11) + (a02*b21 + a03*b31)\n  Thread (0,1): acc = (a10*b00 + a11*b10) + (a12*b20 + a13*b30)\n  Thread (1,1): acc = (a10*b01 + a11*b11) + (a12*b21 + a13*b31)",
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Thread: tx=0, ty=0, row=0, col=0\n\nITERATION t=0 (Load first tile):\n  Thread (0,0) loads: sA[0,0] = A[0,0] = a00\n  Thread (1,0) loads: sA[0,1] = A[0,1] = a01\n  Thread (0,1) loads: sA[1,0] = A[1,0] = a10\n  Thread (1,1) loads: sA[1,1] = A[1,1] = a11\n  All threads load their B elements into sB\n  SYNC 1: Wait for all loads\n\n  Each thread computes partial product from shared memory:\n  Thread (0,0): acc += sA[0,0]*sB[0,0] + sA[0,1]*sB[1,0] = a00*b00 + a01*b10\n  Thread (0,1): acc += sA[1,0]*sB[0,0] + sA[1,1]*sB[1,0] = a10*b00 + a11*b10\n  Thread (1,0): acc += sA[0,0]*sB[0,1] + sA[0,1]*sB[1,1] = a00*b01 + a01*b11\n  Thread (1,1): acc += sA[1,0]*sB[0,1] + sA[1,1]*sB[1,1] = a10*b01 + a11*b11\n  SYNC 2: Wait for all computes before overwriting\n\nITERATION t=1 (Load second tile):\n  Load A[:,2:4] into sA, B[2:4,:] into sB\n  SYNC 1\n  Compute second partial product\n  SYNC 2\n\nFinal: C[0,0] = sum of both partial products",
      "lineHeight": 1.25
    },
