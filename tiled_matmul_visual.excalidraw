      "lineHeight": 1.25
    },
    {
      "type": "text",
      "version": 1,
      "versionNonce": 1,
      "isDeleted": false,
      "id": "comparison-details",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "angle": 0,
      "x": 50,
      "y": 1300,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "width": 900,
      "height": 120,
      "seed": 1,
      "groupIds": [],
      "frameId": null,
      "roundness": null,
      "boundElements": [],
      "updated": 1,
      "link": null,
      "locked": false,
      "fontSize": 13,
      "fontFamily": 3,
      "text": "NAIVE:  Each thread reads entire row/col from global memory → 8K reads/element\nTILED:  Each thread loads tile to shared memory → 8K/T reads/element\n\nFor 1024×1024 with TILE=16:\nNaive:   87 GFLOPS   (AI = 0.25 FLOP/byte)\nTiled:   701 GFLOPS  (AI = 4.0 FLOP/byte)  → 8× speedup!\n\nThe win: 16× fewer global reads, same FLOPs → 16× higher arithmetic intensity\nThe cost: Shared memory + 2 syncthreads() per iteration",
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "NAIVE:  Each thread reads entire row/col from global memory → 8K reads/element\nTILED:  Each thread loads tile to shared memory → 8K/T reads/element\n\nFor 1024×1024 with TILE=16:\nNaive:   87 GFLOPS   (AI = 0.25 FLOP/byte)\nTiled:   701 GFLOPS  (AI = 4.0 FLOP/byte)  → 8× speedup!\n\nThe win: 16× fewer global reads, same FLOPs → 16× higher arithmetic intensity\nThe cost: Shared memory + 2 syncthreads() per iteration",
      "lineHeight": 1.25
    }
  ],
