      "boundElements": [],
      "updated": 1,
      "link": null,
      "locked": false,
      "fontSize": 13,
      "fontFamily": 2,
      "text": "Threads (0,0) and (1,0) both read the same row of A — [a00,a01,a02,a03] —\nbut each reads it independently from global memory.\nThe data is loaded twice instead of once.",
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Threads (0,0) and (1,0) both read the same row of A — [a00,a01,a02,a03] —\nbut each reads it independently from global memory.\nThe data is loaded twice instead of once.",
      "lineHeight": 1.25
    },
